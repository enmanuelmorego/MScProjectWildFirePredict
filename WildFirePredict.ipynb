   "source": [
    "import rasterio\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "with rasterio.open(file) as src:\n",
    "    arr = src.read()\n",
    "\n",
    "# Build RGB\n",
    "rgb = np.stack([arr[2], arr[1], arr[0]], axis=-1)\n",
    "\n",
    "# Scale reflectance properly\n",
    "rgb = rgb / 10000.0\n",
    "rgb = np.clip(rgb, 0, 1)\n",
    "\n",
    "plt.figure(figsize=(6,6))\n",
    "plt.imshow(rgb)\n",
    "plt.axis(\"off\")\n",
    "plt.title(\"Sentinel-2 RGB Composite\")\n",
    "plt.show()\n"
   ]
