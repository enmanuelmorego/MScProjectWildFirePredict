    "import geopandas as gpd\n",
    "import rasterio\n",
    "from shapely.geometry import box\n",
    "\n",
    "\n",
    "\n",
    "with rasterio.open(file) as src:\n",
    "    bounds = src.bounds\n",
    "    crs = src.crs\n",
    "\n",
    "# Create bounding box polygon\n",
    "bbox_geom = box(bounds.left, bounds.bottom,\n",
    "                bounds.right, bounds.top)\n",
    "\n",
    "bbox = gpd.GeoDataFrame(\n",
    "    geometry=[bbox_geom],\n",
